{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "ai-meets-sldc",
  "main": "worker/index.ts",
  "compatibility_date": "2026-04-30",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./build",
    "binding": "ASSETS",
  },
  "routes": [
    {
      "pattern": "sldcai.org",
      "custom_domain": true,
    },
    {
      "pattern": "www.sldcai.org",
      "custom_domain": true,
    },
  ],
}
